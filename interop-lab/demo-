<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import org.mdpnp.guis.waveform.javafx.JavaFXWaveformPane?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.mdpnp.apps.testapp.datavalidation.DataValidationApp"
            style="-fx-background-color: #F4F7FB; -fx-font-family: 'Courier New'; -fx-font-size: 12px;"
            maxHeight="980">

    <!-- ToggleGroup must be in fx:define, not inside any layout node -->
    <fx:define>
        <ToggleGroup fx:id="timeWindowGroup"/>
    </fx:define>

    <!-- TOP - Header (ACLIVA style) -->
    <top>
        <HBox style="-fx-background-color: #0D1B3E; -fx-padding: 8px;">
            <Label text="DATA VALIDATION APP" textFill="WHITE" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS" />
            <Label text="OpenICE  ·  MD PnP / MGH" textFill="WHITE" style="-fx-font-size: 13px;"/>
        </HBox>
    </top>

    <!-- CENTER: three waveform panes + metrics -->
    <center>
        <HBox spacing="10">
            <!-- LEFT PANEL: Configuration and Metrics -->
            <VBox prefWidth="380.0" style="-fx-background-color: #F4F7FB; -fx-border-color: transparent #D3D3D3 transparent transparent; -fx-padding: 10px;" spacing="7.0">

                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="PPG SIGNAL" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>
                <ComboBox fx:id="waveformSelector" prefWidth="360"
                          style="-fx-font-size: 11px;" promptText="Select a PPG Signal..." />

                <Separator style="-fx-padding: 10 0 10 0;" />

                <!-- SQI STATUS -->
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="SIGNAL QUALITY INDEX (SQI)" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>

                <HBox spacing="20">
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="VERDICT" style="-fx-text-fill: #808080; -fx-font-size: 10px; -fx-letter-spacing: 1px;"/>
                        <Label fx:id="verdictLabel" text="--" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox alignment="CENTER_LEFT" spacing="3" prefWidth="180">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="SQI SCORE" style="-fx-text-fill: #808080; -fx-font-size: 10px;"/>
                            <Label fx:id="sqiLabel" text="--" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        </HBox>
                        <ProgressBar fx:id="sqiBar" progress="0" prefWidth="180" style="-fx-accent: #0D1B3E;"/>
                    </VBox>
                </HBox>

                <Separator style="-fx-padding: 10 0 10 0;" />

                <!-- INDIVIDUAL SCORES -->
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="COMPONENTS" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>

                <GridPane hgap="10" vgap="6">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120"/>
                        <ColumnConstraints prefWidth="100"/>
                    </columnConstraints>

                    <Label text="Perfusion:" style="-fx-text-fill: #808080; -fx-font-size: 11px;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="perfLabel" text="--"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Spectral Power:" style="-fx-text-fill: #808080; -fx-font-size: 11px;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="specLabel" text="--"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Autocorrelation:" style="-fx-text-fill: #808080; -fx-font-size: 11px;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="autocorrLabel" text="--"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>

                <VBox spacing="2" style="-fx-padding: 10 0 0 0;">
                    <Label text="LATENCY" style="-fx-text-fill: #808080; -fx-font-size: 10px;"/>
                    <Label fx:id="latencyLabel" text="-- ms" style="-fx-font-size: 11px;"/>
                </VBox>

                <Separator style="-fx-padding: 10 0 10 0;" />

                <!-- TIME WINDOW CONTROL -->
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="TIME WINDOW" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <ToggleButton fx:id="fullRecordToggle" text="Full Record"
                                  toggleGroup="$timeWindowGroup"
                                  style="-fx-font-size: 10px; -fx-padding: 3 8 3 8;"/>
                    <ToggleButton fx:id="rollingWindowToggle" text="Rolling" selected="true"
                                  toggleGroup="$timeWindowGroup"
                                  style="-fx-font-size: 10px; -fx-padding: 3 8 3 8;"/>
                    <Spinner fx:id="windowMinutesSpinner" prefWidth="55" editable="true"
                             style="-fx-font-size: 11px;"/>
                    <Label text="min" style="-fx-font-size: 10px; -fx-text-fill: #808080;"/>
                </HBox>

                <Separator style="-fx-padding: 10 0 10 0;" />

                <!-- SQI THRESHOLD CONTROL -->
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="SQI THRESHOLD" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <Label fx:id="thresholdValueLabel" text="0.40"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #FFC000;"/>
                </HBox>
                <Slider fx:id="thresholdSlider" min="0.10" max="0.90" value="0.40"
                        showTickMarks="true" showTickLabels="true"
                        majorTickUnit="0.20" minorTickCount="1"
                        prefWidth="340" style="-fx-font-size: 9px;"/>

                <Pane VBox.vgrow="ALWAYS" />

                <!-- REFERENCE -->
                <VBox style="-fx-background-color: #E8ECEF; -fx-border-color: #D3D3D3; -fx-padding: 8px;" spacing="5.0">
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label text="●" textFill="#808080" style="-fx-font-size: 10px;"/>
                        <Label text="Reference" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    </HBox>
                    <Label text="Le et al., Front. Physiology 2022"
                           textFill="#808080" style="-fx-font-size: 11px;" wrapText="true" />
                    <Label text="vital_sqi: perfusion + spectral + autocorrelation"
                           textFill="#808080" style="-fx-font-size: 10px; -fx-font-style: italic;" wrapText="true" />
                </VBox>

            </VBox>

            <!-- RIGHT PANEL: Waveforms -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-padding: 14px; -fx-background-color: white;">

                <!-- Pane 1: Raw PPG -->
                <VBox VBox.vgrow="ALWAYS" spacing="3"
                      style="-fx-background-color: #F4F7FB; -fx-border-color: #D3D3D3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="RAW PPG"
                               style="-fx-text-fill: #008080; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                        <Label text="unfiltered signal from DDS bus"
                               style="-fx-text-fill: #808080; -fx-font-size: 10px;"/>
                        <Button fx:id="simulateArtifactBtn"
                                text="Simulate Motion Artifact"
                                onAction="#onSimulateArtifact"
                                style="-fx-background-color: #B85042; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 3 10 3 10; -fx-cursor: hand;"/>
                        <Label fx:id="artifactStatusLabel" text=""
                               style="-fx-text-fill: #E06C1A; -fx-font-size: 10px; -fx-font-style: italic;"/>
                    </HBox>
                    <JavaFXWaveformPane fx:id="rawWaveformPane" VBox.vgrow="ALWAYS" prefHeight="200"/>
                </VBox>

                <!-- Pane 2: SQI trace -->
                <VBox VBox.vgrow="ALWAYS" spacing="3"
                      style="-fx-background-color: #F4F7FB; -fx-border-color: #D3D3D3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="SQI TRACE"
                               style="-fx-text-fill: #FFC000; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                        <Label text="signal quality score per 5s window  |  threshold adjustable  |  scaled to PPG amplitude"
                               style="-fx-text-fill: #808080; -fx-font-size: 10px;"/>
                    </HBox>
                    <JavaFXWaveformPane fx:id="validationSignalPane" VBox.vgrow="ALWAYS" prefHeight="200"/>
                </VBox>

                <!-- Pane 3: Cleaned PPG -->
                <VBox VBox.vgrow="ALWAYS" spacing="3"
                      style="-fx-background-color: #F4F7FB; -fx-border-color: #D3D3D3; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="CLEANED PPG"
                               style="-fx-text-fill: #0D1B3E; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                        <Label text="invalid sections (SQI below threshold) replaced with zero"
                               style="-fx-text-fill: #808080; -fx-font-size: 10px;"/>
                    </HBox>
                    <JavaFXWaveformPane fx:id="validatedWaveformPane" VBox.vgrow="ALWAYS" prefHeight="200"/>
                </VBox>
            </VBox>
        </HBox>
    </center>

    <!-- BOTTOM - Status bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-background-color: #F4F7FB; -fx-border-color: #30363d transparent transparent transparent; -fx-padding: 5 12 5 12;">
            <Label text="STATUS:"
                   style="-fx-text-fill: #484f58; -fx-font-size: 9px; -fx-letter-spacing: 1px;"/>
            <Label fx:id="statusLabel"
                   text="Initializing..."
                   style="-fx-text-fill: #8b949e; -fx-font-size: 10px;"/>
        </HBox>
    </bottom>

</BorderPane>
