<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="error">
	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout>
				<pattern>%d | %-5p | %c{1} | %t | %m%n"</pattern>
			</PatternLayout>
		</Console>
		<RollingFile name="demo-apps-log" fileName="${sys:user.home}/demo-apps.log"
			filePattern="${sys:user.home}/demo-apps.log-%i.log">
			<PatternLayout>
				<pattern>%d | %-5p | %c{1} | %t | %m%n</pattern>
			</PatternLayout>
			<SizeBasedTriggeringPolicy size="1024KB"/>
		</RollingFile>
		<RollingFile name="easy-tiva-log" fileName="${sys:user.home}/easy-tiva.log"
			filePattern="${sys:user.home}/easy-tiva-%i.log" immediateFlush="true">
			<PatternLayout>
				<pattern>%d{DEFAULT} | %-5p | %c{1} | %t | %m%n</pattern>
			</PatternLayout>
			<SizeBasedTriggeringPolicy size="64MB"/>
			<DefaultRolloverStrategy max="1000000"/>
		</RollingFile>
		<RollingFile name="mitm-time-trace-log" fileName="${sys:user.home}/FCTLogs/mitm-timing.log"
			filePattern="${sys:user.home}/FCTLogs/mitm-timing-%i.log" immediateFlush="true">
			<PatternLayout>
				<pattern>%d{DEFAULT} | %-5p | %c{1} | %t | %m%n</pattern>
			</PatternLayout>
			<SizeBasedTriggeringPolicy size="64MB"/>
			<DefaultRolloverStrategy max="1000000"/>
		</RollingFile>
		<RollingFile name="pump-timing-log" fileName="${sys:user.home}/pump-timing.log"
			filePattern="${sys:user.home}/pump-timing-%i.log" immediateFlush="true">
			<PatternLayout>
				<pattern>%d{DEFAULT} | %-5p | %c{1} | %t | %m%n</pattern>
			</PatternLayout>
			<SizeBasedTriggeringPolicy size="1024KB"/>
			<DefaultRolloverStrategy max="1000000"/>
		</RollingFile>
		<RollingFile name="neurowave-alaris-log" fileName="${sys:user.home}/neurowave-alaris.log"
			filePattern="${sys:user.home}/neurowave-alaris-%i.log" immediateFlush="true">
			<PatternLayout>
				<pattern>%d{DEFAULT} | %-5p | %c{1} | %t | %m%n</pattern>
			</PatternLayout>
			<SizeBasedTriggeringPolicy size="64MB"/>
			<DefaultRolloverStrategy max="1000000"/>
		</RollingFile>
	</Appenders>
	<Loggers>
		<Root level="info">
			<AppenderRef ref="demo-apps-log"/>
		</Root>
		<Logger name="easy.tiva" level="trace" additivity="false">
			<AppenderRef ref="easy-tiva-log"/>
		</Logger>
		<Logger name="neurowave.alaris" level="trace" additivity="false">
			<AppenderRef ref="neurowave-alaris-log"/>
		</Logger>
		<Logger name="mitm.timetrace" level="trace" additivity="false">
			<AppenderRef ref="mitm-time-trace-log"/>
		</Logger>
		<Logger name="pump.timing" level="trace" additivity="false">
			<AppenderRef ref="pump-timing-log"/>
		</Logger>
	</Loggers>

</Configuration>