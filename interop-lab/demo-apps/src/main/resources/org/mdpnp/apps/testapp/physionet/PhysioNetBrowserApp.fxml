<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeTableColumn?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.mdpnp.apps.testapp.physionet.PhysioNetBrowserApp"
            style="-fx-background-color: #0d1117; -fx-font-family: 'Courier New'; -fx-font-size: 12px;">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TOP — Header + Credentials                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #161b22; -fx-border-color: transparent transparent #30363d transparent;">
            <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
            <spacing>6</spacing>

            <!-- Title row -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="PHYSIONET BROWSER"
                       style="-fx-text-fill: #58a6ff; -fx-font-size: 17px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                <Label text="OpenICE · PARADIGM · MD PnP / MGH"
                       style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>
            </HBox>

            <!-- Credentials row -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Username:"
                       style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>
                <TextField fx:id="usernameField"
                           promptText="PhysioNet username"
                           prefWidth="160"
                           style="-fx-background-color: #21262d; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #c9d1d9; -fx-font-size: 11px;"/>
                <Label text="Password:"
                       style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="PhysioNet password"
                               prefWidth="160"
                               style="-fx-background-color: #21262d; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #c9d1d9; -fx-font-size: 11px;"/>
                <Label text="Required for credentialed datasets (MIMIC, VTaC)"
                       style="-fx-text-fill: #484f58; -fx-font-size: 10px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CENTER — Three-panel split                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <center>
        <SplitPane dividerPositions="0.27, 0.47"
                   style="-fx-background-color: #0d1117;">

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- PANEL 1 — Database list                                     -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <VBox style="-fx-background-color: #0d1117;" spacing="6">
                <padding><Insets top="10" right="6" bottom="6" left="8"/></padding>

                <Label text="DATABASES"
                       style="-fx-text-fill: #58a6ff; -fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>

                <!-- Search + priority filter -->
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <TextField fx:id="dbSearchField"
                               promptText="Filter databases…"
                               style="-fx-background-color: #21262d; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #c9d1d9; -fx-font-size: 11px;"
                               HBox.hgrow="ALWAYS"/>
                    <CheckBox fx:id="priorityOnlyCb"
                              text="⭐ Only"
                              style="-fx-text-fill: #8b949e; -fx-font-size: 10px;"/>
                </HBox>

                <ListView fx:id="dbListView"
                          style="-fx-background-color: #161b22; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-control-inner-background: #161b22; -fx-text-fill: #c9d1d9;"
                          VBox.vgrow="ALWAYS"/>

                <Label fx:id="dbCountLabel"
                       text=""
                       style="-fx-text-fill: #484f58; -fx-font-size: 10px;"/>
            </VBox>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- PANEL 2 — Record list                                       -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <VBox style="-fx-background-color: #0d1117;" spacing="6">
                <padding><Insets top="10" right="6" bottom="6" left="6"/></padding>

                <Label text="RECORDS"
                       style="-fx-text-fill: #58a6ff; -fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>

                <TextField fx:id="recSearchField"
                           promptText="Filter records…"
                           style="-fx-background-color: #21262d; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #c9d1d9; -fx-font-size: 11px;"/>

                <ListView fx:id="recListView"
                          style="-fx-background-color: #161b22; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-control-inner-background: #161b22; -fx-text-fill: #c9d1d9;"
                          VBox.vgrow="ALWAYS"/>

                <Label fx:id="recCountLabel"
                       text=""
                       style="-fx-text-fill: #484f58; -fx-font-size: 10px;"/>
            </VBox>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- PANEL 3 — Signal info + Download                            -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <VBox style="-fx-background-color: #0d1117;" spacing="6">
                <padding><Insets top="10" right="8" bottom="8" left="6"/></padding>

                <Label text="SIGNAL INFO"
                       style="-fx-text-fill: #58a6ff; -fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>

                <!-- Signal tree table -->
                <TreeTableView fx:id="signalTreeTable"
                               prefHeight="280"
                               style="-fx-background-color: #161b22; -fx-border-color: #30363d; -fx-border-radius: 4;"
                               VBox.vgrow="SOMETIMES">
                    <columns>
                        <TreeTableColumn fx:id="propCol" text="Property" prefWidth="200"/>
                        <TreeTableColumn fx:id="valCol"  text="Value"    prefWidth="340"/>
                    </columns>
                </TreeTableView>

                <!-- MDC coverage badge -->
                <Label fx:id="coverageBadgeLabel"
                       text=""
                       style="-fx-text-fill: #8b949e; -fx-font-size: 11px; -fx-font-weight: bold;"/>

                <!-- Header comments -->
                <TextArea fx:id="commentsArea"
                          promptText="Record comments / metadata…"
                          editable="false"
                          prefHeight="80"
                          wrapText="true"
                          style="-fx-background-color: #161b22; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-text-fill: #8b949e; -fx-font-size: 11px;"/>

                <!-- Separator -->
                <Label text="DOWNLOAD"
                       style="-fx-text-fill: #58a6ff; -fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>

                <!-- Selected record label -->
                <Label fx:id="selectedLabel"
                       text="No record selected."
                       style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>

                <!-- Fixed download path label -->
                <Label fx:id="downloadPathLabel"
                       text=""
                       style="-fx-text-fill: #484f58; -fx-font-size: 10px;"/>

                <!-- Download button + progress -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="downloadBtn"
                            text="⬇  Download Selected Record"
                            onAction="#onDownload"
                            style="-fx-background-color: #1f6feb; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 5 14 5 14;"/>
                    <ProgressBar fx:id="progressBar"
                                 prefWidth="160"
                                 style="-fx-accent: #1f6feb;"/>
                </HBox>

                <!-- Download log -->
                <TextArea fx:id="logArea"
                          promptText="Download log…"
                          editable="false"
                          wrapText="true"
                          style="-fx-background-color: #161b22; -fx-border-color: #30363d; -fx-border-radius: 4; -fx-text-fill: #c9d1d9; -fx-font-family: 'Courier New'; -fx-font-size: 11px;"
                          VBox.vgrow="ALWAYS"/>

            </VBox>

        </SplitPane>
    </center>

</BorderPane>
