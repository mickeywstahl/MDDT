<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.geometry.HPos?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="186.0" prefWidth="800.0" xmlns:fx="http://javafx.com/fxml/1" fx:id="main" fx:controller="org.mdpnp.apps.testapp.pumps.AP4000vINTChannelController" style="-fx-border-style: solid">
  <children>
      <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="800.0">
         <children>
            <Label fx:id="channelLabel" text="- Channel " />
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label text="-- Drug Info --" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label text="-- Infusion Status --" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="400.0">
               <children>
                  <Label text="-- Infusion Control --" />
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="drugLabel" contentDisplay="RIGHT" text=" Drug: " />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="infusionRateLabel" text="Infusion Rate(ml/h): " />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="125.0" text="Infusion Rate (ml/h) " />
                  <Spinner fx:id="targetInfusionRate" editable="true" prefWidth="65.0">
                  <valueFactory>
       			   <SpinnerValueFactory.IntegerSpinnerValueFactory max="1200" min="1" />	<!--We could set min and max here if we knew what they were-->
                  </valueFactory>
                  </Spinner>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="125.0" text="Bolus Dose (ml) " />
                  <Spinner fx:id="bolusDose" editable="true" prefWidth="65.0">
                  <valueFactory>
       			   <SpinnerValueFactory.IntegerSpinnerValueFactory max="1000" min="0" />	<!--We could set min and max here if we knew what they were-->
                  </valueFactory>
                  </Spinner>
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="concentrationLabel" text="Concentration(mg/ml): " />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="volumeInfusedLabel" text="Volume Infused(ml): " />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="125.0" text="VTBI (ml) " />
                  <Spinner fx:id="targetVTBI" editable="true" prefWidth="65.0">
                  <valueFactory>
       			   <SpinnerValueFactory.IntegerSpinnerValueFactory max="1000" min="0" />	<!--We could set min and max here if we knew what they were-->
                  </valueFactory>
                  </Spinner>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                 <Label prefHeight="17.0" prefWidth="125.0" text="Bolus Rate (ml/h) " />
                  <Spinner fx:id="bolusRate" editable="true" prefWidth="65.0">
                  <valueFactory>
       			   <SpinnerValueFactory.IntegerSpinnerValueFactory max="1000" min="0" />	<!--We could set min and max here if we knew what they were-->
                  </valueFactory>
                  </Spinner>
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox prefHeight="25.0" prefWidth="200.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="targetVolumeInfusedLabel" text="Target Volume(ml): " />
               </children>
            </HBox>
            <HBox prefHeight="25.0" prefWidth="200.0" />
            <HBox prefHeight="25.0" prefWidth="200.0" />
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox prefHeight="25.0" prefWidth="200.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="26.0" prefWidth="200.0">
               <children>
                  <Label fx:id="currentBolusInfusedLabel" text="Current Bolus Infused(ml): " />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="25.0" prefWidth="100.0">
               <children>
                  <Button fx:id="setProgram" mnemonicParsing="false" onAction="#programInfusion" text="Set" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="26.0" prefWidth="100.0">
               <children>
                  <Button fx:id="pauseResumeInfusion" mnemonicParsing="false" onAction="#pauseResumeInfusion" text="Pause/Start" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Button fx:id="startBolus" mnemonicParsing="false" onAction="#programBolus" text="Start Bolus" />
               </children>
            </HBox>
         </children>
      </HBox>
      <HBox prefHeight="25.0" prefWidth="800.0">
         <children>
            <HBox prefHeight="25.0" prefWidth="200.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Label fx:id="totalBolusInfusedLabel" text="Total Bolus Infused(ml):" />
               </children>
            </HBox>
            <HBox prefHeight="25.0" prefWidth="200.0" />
            <HBox prefHeight="25.0" prefWidth="200.0" />
         </children>
      </HBox>
   </children>
</VBox>
