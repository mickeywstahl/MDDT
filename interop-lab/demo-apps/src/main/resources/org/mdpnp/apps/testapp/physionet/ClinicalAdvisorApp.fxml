<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.mdpnp.apps.testapp.physionet.ClinicalAdvisorApp"
            maxHeight="980">

    <!-- TOP - Header -->
    <top>
        <HBox style="-fx-background-color: #0D1B3E; -fx-padding: 8px;">
            <Label text="CLINICAL ADVISOR" textFill="WHITE" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS" />
            <Label fx:id="modelLabel" text="" textFill="WHITE" style="-fx-font-size: 13px;"/>
        </HBox>
    </top>

    <!-- CENTER - Main content -->
    <center>
        <HBox>
            <!-- LEFT - Primary diagnosis panel -->
            <VBox prefWidth="380.0" style="-fx-background-color: #F4F7FB; -fx-border-color: transparent #D3D3D3 transparent transparent; -fx-padding: 10px;" spacing="7.0">

                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="PRIMARY DIAGNOSIS" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>

                <Label fx:id="primaryDiagnosisLabel"
                       text="Waiting..."
                       wrapText="true"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ProgressBar fx:id="primaryConfidenceBar"
                                 progress="0"
                                 prefWidth="220" />
                    <Label fx:id="primaryConfidenceLabel"
                           text="--"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <Label fx:id="primaryStatusLabel"
                       text="No data received"
                       textFill="#808080" style="-fx-font-size: 11px;"/>

                <Separator />

                <!-- 6-condition probability bars -->
                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="CONDITION PROBABILITIES" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>

                <GridPane hgap="8" vgap="6">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="180"/>
                        <ColumnConstraints prefWidth="110"/>
                        <ColumnConstraints prefWidth="50"/>
                    </columnConstraints>

                    <!-- Row 0: 1dAVb -->
                    <Label fx:id="lbl1dAVb" text="1st Degree AV Block"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="bar1dAVb" progress="0" prefWidth="110"
                                 GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label fx:id="pct1dAVb" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                    <!-- Row 1: RBBB -->
                    <Label fx:id="lblRBBB" text="Right Bundle Branch Block"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="barRBBB" progress="0" prefWidth="110"
                                 GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label fx:id="pctRBBB" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="1" GridPane.columnIndex="2"/>

                    <!-- Row 2: LBBB -->
                    <Label fx:id="lblLBBB" text="Left Bundle Branch Block"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="barLBBB" progress="0" prefWidth="110"
                                 GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label fx:id="pctLBBB" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="2" GridPane.columnIndex="2"/>

                    <!-- Row 3: SB -->
                    <Label fx:id="lblSB" text="Sinus Bradycardia"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="barSB" progress="0" prefWidth="110"
                                 GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label fx:id="pctSB" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="3" GridPane.columnIndex="2"/>

                    <!-- Row 4: AF -->
                    <Label fx:id="lblAF" text="Atrial Fibrillation"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="barAF" progress="0" prefWidth="110"
                                 GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <Label fx:id="pctAF" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="4" GridPane.columnIndex="2"/>

                    <!-- Row 5: ST -->
                    <Label fx:id="lblST" text="Sinus Tachycardia"
                           style="-fx-font-size: 11px;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <ProgressBar fx:id="barST" progress="0" prefWidth="110"
                                 GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    <Label fx:id="pctST" text="--"
                           textFill="#808080" style="-fx-font-size: 11px;"
                           GridPane.rowIndex="5" GridPane.columnIndex="2"/>
                </GridPane>

                <Separator />

                <!-- Timing -->
                <Label fx:id="inferenceTimeLabel" text="Last inference: --"
                       textFill="#808080" style="-fx-font-size: 11px;"/>
                <Label fx:id="latencyLabel" text="Inference time: --"
                       textFill="#808080" style="-fx-font-size: 11px;"/>

            </VBox>

            <!-- RIGHT - Log and status -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-padding: 14px; -fx-background-color: white;">

                <HBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="●" textFill="#008080" style="-fx-font-size: 10px;"/>
                    <Label text="ACTIVITY LOG" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                </HBox>

                <TextArea fx:id="logArea"
                          editable="false"
                          wrapText="true"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-family: monospace; -fx-font-size: 11px; -fx-control-inner-background: #E8ECEF;"/>

                <!-- Reference -->
                <VBox style="-fx-background-color: #E8ECEF; -fx-border-color: #D3D3D3; -fx-padding: 8px;" spacing="5.0">
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label text="●" textFill="#808080" style="-fx-font-size: 10px;"/>
                        <Label text="Reference" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    </HBox>
                    <Label text="Ribeiro et al. Automatic diagnosis of the 12-lead ECG using a deep neural network. Nature Communications 11, 1760 (2020)."
                           textFill="#808080" style="-fx-font-size: 11px;" wrapText="true" />
                    <Label text="Model outperforms cardiology residents on 6 ECG abnormalities."
                           textFill="#808080" style="-fx-font-size: 10px; -fx-font-style: italic;" wrapText="true" />
                </VBox>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #F4F7FB; -fx-padding: 5px 16px;">
            <HBox alignment="CENTER_LEFT" spacing="5">
                <Rectangle fx:id="statusIndicator" width="10" height="10" arcWidth="10" arcHeight="10" fill="#D3D3D3"/>
                <Label fx:id="statusLabel" text="Initializing..." textFill="#808080" style="-fx-font-size: 10px;" />
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <Label text="OpenICE  ·  MD PnP / MGH" textFill="#808080" style="-fx-font-size: 10px;" />
        </HBox>
    </bottom>

</BorderPane>